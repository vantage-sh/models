---
import data from "../data";

const formattedDate = new Date(data.scrapedAt).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
});
---

<footer class="border-t border-border h-[3rem] sticky bottom-0 text-xs text-muted-foreground bg-background z-10">
    <div class="flex items-center justify-between h-full px-4">
        <div class="hidden md:block">
            Updated {formattedDate}
        </div>
        <div class="hidden md:block">
            vantage.sh/models &mdash; AI Model Comparison
        </div>
        <div class="flex items-center gap-3">
            <a
                href="https://vantage.sh/slack"
                target="_blank"
                class="text-[#6742d6] dark:text-purple-300 hover:underline"
            >
                Slack
            </a>
            <span>
                By{" "}
                <a
                    target="_blank"
                    href="https://www.vantage.sh/?utm_source=models"
                    class="text-[#6742d6] dark:text-purple-300 hover:underline"
                >
                    Vantage
                </a>
            </span>
        </div>
    </div>
</footer>
