---
import Link from "./Link";
---
<header class="bg-[#6742d6] text-white h-[4rem] px-4">
    <div class="w-full h-full flex items-center">
        <Link href={import.meta.env.PUBLIC_BASE_URL ?? "/"} unstyled>
            <div class="flex items-center gap-4 h-full">
                <img
                    src="data:image/svg+xml;base64,"
                    alt="Vantage Logo"
                    class="h-8"
                />
                <div class="block h-max">
                    <p class="font-semibold">vantage.sh/models</p>
                    <p class="text-sm text-gray-200 dark:text-gray-300">Powered by Vantage</p>
                </div>
            </div>
        </Link>
    </div>
</header>
