---
import data from "../../data";
import MainLayout from "../../layouts/MainLayout.astro";
import ModelPage from "../../components/model/ModelPage";
import { oxfordify } from "@/src/lib/utils";

export function getStaticPaths() {
    return Object.keys(data.models).map((modelId) => ({
        params: { id: modelId },
    }));
}

const { id } = Astro.params;
const model = data.models[id];
const modelName = model?.cleanName ?? id;

const vendors = oxfordify(
    model.vendors.map((vendor) => data.vendors[vendor.vendorRef].cleanName),
);

const description = `${modelName} is a ${model.reasoning ? "reasoning" : "non-reasoning"} model created by ${model.company}. It is served by ${vendors}.`;

const titleExtra = `${modelName} Pricing, Scores, and Specifications`;

const basePath = import.meta.env.PUBLIC_BASE_PATH ?? "";
const siteRootHref = Astro.site ? new URL(basePath || "/", Astro.site).href.replace(/\/$/, "") : "";
const pageHref = Astro.site
    ? new URL(
          Astro.url.pathname.length > 1 && Astro.url.pathname.endsWith("/")
              ? Astro.url.pathname.slice(0, -1)
              : Astro.url.pathname,
          Astro.site,
      ).href
    : "";

const jsonLd = Astro.site
    ? {
          "@context": "https://schema.org",
          "@graph": [
              {
                  "@type": "WebPage",
                  "@id": `${pageHref}#webpage`,
                  name: titleExtra,
                  description,
                  url: pageHref,
                  isPartOf: { "@id": `${siteRootHref}#website` },
              },
              {
                  "@type": "BreadcrumbList",
                  itemListElement: [
                      {
                          "@type": "ListItem",
                          position: 1,
                          name: "LLM models",
                          item: siteRootHref,
                      },
                      {
                          "@type": "ListItem",
                          position: 2,
                          name: modelName,
                          item: pageHref,
                      },
                  ],
              },
          ],
      }
    : null;
---

<MainLayout titleExtra={titleExtra} description={description} jsonLd={jsonLd}>
    <ModelPage
        modelId={id}
        model={model}
        vendors={data.vendors}
        description={description}
        isLlm={true}
        client:load
    />
</MainLayout>
