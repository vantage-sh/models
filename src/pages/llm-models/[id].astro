---
import data from "../../data";
import MainLayout from "../../layouts/MainLayout.astro";
import ModelPage from "../../components/model/ModelPage";
import { oxfordify } from "@/src/lib/utils";

export function getStaticPaths() {
    return Object.keys(data.models).map((modelId) => ({
        params: { id: modelId },
    }));
}

const { id } = Astro.params;
const model = data.models[id];
const modelName = model?.cleanName ?? id;

const vendors = oxfordify(
    model.vendors.map((vendor) => data.vendors[vendor.vendorRef].cleanName),
);

const description = `${modelName} is a ${model.reasoning ? "reasoning" : "non-reasoning"} model created by ${model.company}. It is served by ${vendors}.`;
---

<MainLayout titleExtra={`${modelName} Pricing, Scores, and Specifications`} description={description}>
    <ModelPage
        modelId={id}
        model={model}
        vendors={data.vendors}
        description={description}
        isLlm={true}
        client:load
    />
</MainLayout>
