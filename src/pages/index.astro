---
import Table from '../components/Table';
import { getModelIdsAndNames, getImageModelIdsAndNames } from '../sqlEngine';
import data from "../data";
import MainLayout from '../layouts/MainLayout.astro';

// Get the models for the server-side
const llmModels = getModelIdsAndNames(data);
const imageModels = getImageModelIdsAndNames(data);
---

<MainLayout>
    <Table llmModels={llmModels} imageModels={imageModels} vendors={data.vendors} client:only="react" />
</MainLayout>
