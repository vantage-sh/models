---
import Table from '../components/Table';
import { getModelIdsAndNames } from '../sqlEngine';
import data from "../data";
import MainLayout from '../layouts/MainLayout.astro';

const llmModels = getModelIdsAndNames(data);
---

<MainLayout>
    <Table models={llmModels} vendors={data.vendors} modelType="llm" client:load />
</MainLayout>
