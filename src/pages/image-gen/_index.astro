---
import Table from '../../components/Table';
import { getImageModelIdsAndNames } from '../../sqlEngine';
import data from "../../data";
import MainLayout from '../../layouts/MainLayout.astro';

const imageModels = getImageModelIdsAndNames(data);

const titleExtra = "Image generation pricing and specifications";
const description =
    "Compare image generation API pricing and specs across major cloud vendors. Per-image costs, resolution limits, and model metadata in one sortable table.";

const basePath = import.meta.env.PUBLIC_BASE_PATH ?? "";
const pageHref = Astro.site
    ? new URL(
          Astro.url.pathname.length > 1 && Astro.url.pathname.endsWith("/")
              ? Astro.url.pathname.slice(0, -1)
              : Astro.url.pathname,
          Astro.site,
      ).href
    : "";
const siteRootHref = Astro.site ? new URL(basePath || "/", Astro.site).href.replace(/\/$/, "") : "";

const jsonLd = Astro.site
    ? {
          "@context": "https://schema.org",
          "@graph": [
              {
                  "@type": "WebSite",
                  "@id": `${siteRootHref}#website`,
                  name: "vantage.sh/models",
                  url: siteRootHref,
                  description:
                      "Open-source comparison of AI model pricing, benchmarks, and specifications from major cloud vendors.",
              },
              {
                  "@type": "WebPage",
                  "@id": `${pageHref}#webpage`,
                  name: titleExtra,
                  description,
                  url: pageHref,
                  isPartOf: { "@id": `${siteRootHref}#website` },
              },
          ],
      }
    : null;
---

<MainLayout titleExtra={titleExtra} description={description} jsonLd={jsonLd}>
    <h1 class="sr-only">{titleExtra}</h1>
    <Table models={imageModels} vendors={data.vendors} isLlm={false} scrapedAt={data.scrapedAt} client:only="react" />
</MainLayout>
